{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/.astro",
			"!**/*.astro",
			"!**/dist",
			"!**/node_modules",
			"!**/coverage",
			"!**/build",
			"!**/*.min.js",
			"!**/*.d.ts",
			"!**/.claude"
		]
	},
	"css": { "parser": { "tailwindDirectives": true } },
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100,
		"includes": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "**/*.json"]
	},
	"overrides": [
		{
			"includes": [
				"**/packages/library/src/components/SwipeBarLeft.tsx",
				"**/packages/library/src/components/SwipeBarRight.tsx",
				"**/packages/library/src/components/SwipeBarBottom.tsx"
			],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off"
					}
				}
			}
		}
	],
	"javascript": {
		"formatter": {
			"semicolons": "always",
			"trailingCommas": "all",
			"quoteStyle": "double"
		}
	}
}
