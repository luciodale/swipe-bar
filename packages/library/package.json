{
	"name": "@luciodale/swipe-bar",
	"version": "1.3.9",
	"author": "Lucio D'Alessandro",
	"repository": {
		"type": "git",
		"url": "https://github.com/luciodale/swipe-bar"
	},
	"main": "dist/swipe-bar.umd.js",
